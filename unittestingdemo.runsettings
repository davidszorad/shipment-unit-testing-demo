<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <!-- Excludes the deliberately failing/brittle D1 demo artefact so CI stays green.
         Equivalent to running: dotnet test with filter TestCategory not equal DemoOnly -->
    <TestCaseFilter>TestCategory!=DemoOnly</TestCaseFilter>
  </RunConfiguration>
  <MSTest>
    <Parallelize>
      <Workers>0</Workers>
      <Scope>MethodLevel</Scope>
    </Parallelize>
  </MSTest>
</RunSettings>
